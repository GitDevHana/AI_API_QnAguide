# ── DB ──────────────────────────────────────────
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_secret
POSTGRES_DB=copilot_db
POSTGRES_HOST=db           # docker-compose 서비스명
POSTGRES_PORT=5432
DATABASE_URL=postgresql://copilot:copilot_secret@db:5432/copilot_db

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Provider ──────────────────────────────────
# 사용할 provider 한 개만 키를 입력하면 됨
AI_PROVIDER=gemini            # openai | anthropic | gemini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# AI 설정
AI_MODEL=gemini-2.5-flash-lite-preview-04-17  # 무료 티어 최고 한도
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3

# ── App ──────────────────────────────────────────
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ── Rate Limit ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
